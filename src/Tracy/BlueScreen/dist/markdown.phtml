 */ ?>
This is an error page generated by Tracy (https://tracy.nette.org).

<?php $_blocks = [] ?>
<?php $_blocks['renderSource'] = function ($file, $line) use (&$_blocks) { ?>
<?php $srcLines = @file($file) ?>
<?php if ($srcLines): ?>
<?php $start = (int) max(0, $line - 6) ?>
<?php $end = (int) min(count($srcLines), $line + 4) ?>

```php
<?php foreach (array_slice($srcLines, $start, $end - $start, true) as $i => $srcLine): ?>
<?= sprintf('%s%4d | %s', $i + 1 === $line ? ' > ' : '   ', $i + 1, rtrim($srcLine)) ?>

<?php endforeach ?>
```
<?php $mapped = Debugger::mapSource($file, $line) ?>
<?php if ($mapped && @is_file($mapped['file'])): ?>
<?php $mLine = $mapped['line'] ?>

Mapped source: <?= $mapped['file'] . ($mLine ? ':' . $mLine : '') ?>

<?php $mappedLines = @file($mapped['file']) ?>
<?php if ($mappedLines && $mLine): ?>
<?php $mStart = (int) max(0, $mLine - 6) ?>
<?php $mEnd = (int) min(count($mappedLines), $mLine + 4) ?>

```
<?php foreach (array_slice($mappedLines, $mStart, $mEnd - $mStart, true) as $i => $srcLine): ?>
<?= sprintf('%s%4d | %s', $i + 1 === $mLine ? ' > ' : '   ', $i + 1, rtrim($srcLine)) ?>

<?php endforeach ?>
```
<?php endif ?>
<?php endif ?>
<?php endif ?>
<?php } ?>
<?php foreach (Helpers::getExceptionChain($exception) as $i => $ex): ?>
<?php $title = $ex instanceof \ErrorException ? Helpers::errorTypeToString($ex->getSeverity()) : get_debug_type($ex) ?>
<?php $code = $ex->getCode() ? ' #' . $ex->getCode() : '' ?>
<?php if ($i === 0): ?>
# <?= $title ?>: <?= $ex->getMessage() ?><?= $code ?>

<?php else: ?>

## Caused by: <?= $title ?>: <?= $ex->getMessage() ?><?= $code ?>

<?php endif ?>

in <?= $ex->getFile() ?>:<?= $ex->getLine() ?>

<?php $_blocks['renderSource']($ex->getFile(), $ex->getLine()) ?>
<?php $base = new \Exception ?>
<?php if (count(get_mangled_object_vars($ex)) > count(get_mangled_object_vars($base))): ?>

## Exception Properties

<?= Dumper::toText($ex, [Dumper::DEPTH => $blueScreen->maxDepth, Dumper::TRUNCATE => $blueScreen->maxLength, Dumper::ITEMS => $blueScreen->maxItems, Dumper::SCRUBBER => $blueScreen->scrubber, Dumper::KEYS_TO_HIDE => $blueScreen->keysToHide]) ?>

<?php endif ?>
<?php $stack = BlueScreen::cleanStackTrace($ex->getTrace()) ?>
<?php if ($stack): ?>

## Stack Trace

<?php foreach ($stack as $j => $row): ?>
<?php $call = isset($row['class']) ? $row['class'] . ($row['type'] ?? '::') . $row['function'] . '()' : $row['function'] . '()' ?>
<?php $location = isset($row['file']) ? $row['file'] . ':' . ($row['line'] ?? '?') : 'inner-code' ?>
<?= $j + 1 ?>. <?= $call ?>  <?= $location ?>

<?php if (!empty($row['args'])): ?>
<?php try { ?>
<?php $params = isset($row['class']) ? (new \ReflectionMethod($row['class'], $row['function']))->getParameters() : (new \ReflectionFunction($row['function']))->getParameters() ?>
<?php } catch (\Throwable) { ?>
<?php $params = [] ?>
<?php } ?>
<?php foreach ($row['args'] as $k => $v): ?>
<?php $name = isset($params[$k]) && !$params[$k]->isVariadic() ? '$' . $params[$k]->getName() : '#' . $k ?>
<?= '   ' . $name . ' = ' . Dumper::toText($v, [Dumper::DEPTH => 2, Dumper::TRUNCATE => 100]) ?>

<?php endforeach ?>
<?php endif ?>
<?php endforeach ?>
<?php $shown = 0 ?>
<?php foreach ($stack as $row): ?>
<?php if ($shown >= 2) { continue; } ?>
<?php if (isset($row['file'], $row['line']) && @is_file($row['file'])): ?>
<?php $_blocks['renderSource']($row['file'], $row['line']) ?>
<?php $shown++ ?>
<?php endif ?>
<?php endforeach ?>
<?php endif ?>
<?php endforeach ?>
<?php if ($lastError): ?>

## Last Muted Error

<?= Helpers::errorTypeToString($lastError['type']) ?>: <?= $lastError['message'] ?>

in <?= $lastError['file'] ?>:<?= $lastError['line'] ?>

<?php if (@is_file($lastError['file'])): ?>
<?php $_blocks['renderSource']($lastError['file'], $lastError['line']) ?>
<?php endif ?>
<?php endif ?>
<?php if (!Helpers::isCli() && isset($_SERVER['REQUEST_METHOD'])): ?>

## HTTP Request

<?= $_SERVER['REQUEST_METHOD'] ?> <?= $source ?>


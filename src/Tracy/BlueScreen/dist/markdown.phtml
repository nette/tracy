<?php use Tracy\BlueScreen ?>
<?php use Tracy\Debugger ?>
<?php use Tracy\Dumper ?>
<?php use Tracy\Helpers ?>
<?php /**
 * BlueScreen rendered as markdown text (for AI agents and CLI).

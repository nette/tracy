<?php if ($i === 0): ?>
# <?= $title ?>: <?= $ex->getMessage() ?><?= $code ?>

<?php else: ?>

## Caused by: <?= $title ?>: <?= $ex->getMessage() ?><?= $code ?>

<?php endif ?>

in <?= $ex->getFile() ?>:<?= $ex->getLine() ?>

<?php $_blocks['renderSource']($ex->getFile(), $ex->getLine()) ?>

<?php $base = new \Exception ?>
<?php if (count(get_mangled_object_vars($ex)) > count(get_mangled_object_vars($base))): ?>

## Exception Properties

<?= $agentDump($ex) ?>

<?php endif ?>

<?php $stack = $blueScreen->cleanStackTrace($ex->getTrace()) ?>
<?php if ($stack): ?>

## Stack Trace

<?php foreach ($stack as $j => $row): ?>
<?php $funcName = isset($row['class']) ? $row['class'] . ($row['type'] ?? '::') . $row['function'] : $row['function'] ?>
<?php $location = isset($row['file']) ? $row['file'] . ':' . ($row['line'] ?? '?') : 'inner-code' ?>
<?php $inlineArgs = '' ?>
<?php $complexArgs = [] ?>
<?php if (!empty($row['args'])): ?>
<?php try { ?>
<?php $params = isset($row['class']) ? (new \ReflectionMethod($row['class'], $row['function']))->getParameters() : (new \ReflectionFunction($row['function']))->getParameters() ?>
<?php } catch (\Throwable) { ?>
<?php $params = [] ?>
<?php } ?>
<?php $allSimple = true ?>
<?php $argParts = [] ?>
<?php foreach ($row['args'] as $k => $v): ?>
<?php $name = isset($params[$k]) && !$params[$k]->isVariadic() ? '$' . $params[$k]->getName() : '#' . $k ?>
<?php $dump = rtrim($agentDump($v)) ?>
<?php if (str_contains($dump, "\n") || strlen($dump) > 50): ?>
<?php $allSimple = false ?>
<?php $complexArgs[] = '   ' . $name . ' = ' . str_replace("\n", "\n      ", $dump) ?>
<?php else: ?>
<?php $argParts[] = $name . ' = ' . $dump ?>
<?php $complexArgs[] = '   ' . $name . ' = ' . $dump ?>
<?php endif ?>
<?php endforeach ?>
<?php if ($allSimple): ?>
<?php $inlineArgs = implode(', ', $argParts) ?>
<?php endif ?>
<?php endif ?>
<?php if ($inlineArgs): ?>
<?= $j + 1 ?>. <?= $funcName ?>(<?= $inlineArgs ?>)
<?php else: ?>
<?= $j + 1 ?>. <?= $funcName ?>()
<?php endif ?>
   in <?= $location ?>

<?php if (!$inlineArgs && $complexArgs): ?>
<?php foreach ($complexArgs as $arg): ?>
<?= $arg ?>

<?php endforeach ?>
<?php endif ?>
<?php if (isset($row['file'], $row['line']) && @is_file($row['file'])): ?>
<?php $_blocks['renderSource']($row['file'], $row['line']) ?>
<?php endif ?>

<?php endforeach ?>
<?php endif ?>
<?php endforeach ?>

